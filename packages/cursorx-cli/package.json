{
  "name": "cursorx-cli",
  "version": "0.2.0",
  "description": "CLI for installing CursorX slash commands",
  "type": "module",
  "homepage": "https://github.com/haoyinag/CursorX/tree/master/packages/cursorx-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haoyinag/CursorX.git",
    "directory": "packages/cursorx-cli"
  },
  "bugs": {
    "url": "https://github.com/haoyinag/CursorX/issues"
  },
  "keywords": [
    "cursor",
    "cursor-commands",
    "slash-commands",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "cursorx": "bin/cursorx.js"
  },
  "scripts": {
    "list": "node ./bin/cursorx.js list",
    "check": "node ./bin/cursorx.js list && npm pack --dry-run",
    "sync-data": "node ../../scripts/sync-cursorx-cli-data.mjs",
    "prepack": "node ../../scripts/sync-cursorx-cli-data.mjs"
  },
  "files": [
    "bin",
    "src",
    "slash-commands",
    "README.md"
  ],
  "license": "MIT"
}
