      "commands": ["staged-review", "risk-scan"],
      "category": "collaboration",
      "tags": ["review", "pull-request", "risk", "quality"]
    },
    {
      "id": "debug-and-fix",
      "title": "排查与修复",
      "path": "workflows/debug-and-fix.md",
      "summary": "从发现问题到定位、修复、验证的完整流程。",
      "commands": ["staged-review", "test-plan", "git-push"],
