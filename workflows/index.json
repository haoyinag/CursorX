      "commands": ["lint-fix", "test-plan", "staged-review", "git-push"],
      "category": "daily",
      "tags": ["feature", "lint", "test", "commit", "workflow"]
    },
    {
      "id": "pr-preparation",
      "title": "PR 准备",
      "path": "workflows/pr-preparation.md",
      "summary": "提 PR 前一次做完审查、测试计划和摘要。",
      "commands": ["staged-review", "test-plan", "pr-summary"],
      "category": "collaboration",
      "tags": ["pull-request", "review", "test", "summary"]
    },
    {
      "id": "doc-update",
      "title": "文档更新",
