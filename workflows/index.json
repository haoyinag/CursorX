    {
      "id": "onboarding-new-project",
      "title": "新项目接入",
      "path": "workflows/onboarding-new-project.md",
      "summary": "在新仓库装好 CursorX 并跑通第一条工作流。",
      "commands": [],
      "category": "onboarding",
      "tags": ["setup", "install", "onboarding"]
    },
    {
      "id": "code-review-as-reviewer",
      "title": "代码审查（作为 reviewer）",
      "path": "workflows/code-review-as-reviewer.md",
