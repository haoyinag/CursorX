[
  {
    "key": "ctrl+shift+p",
    "command": "workbench.action.showCommands"
  },
  {
    "key": "ctrl+p",
    "command": "workbench.action.quickOpen"
  },
  {
    "key": "ctrl+shift+f",
    "command": "workbench.action.findInFiles"
  },
  {
    "key": "ctrl+alt+c",
    "command": "workbench.action.chat.open"
  },
  {
    "key": "ctrl+alt+q",
    "command": "workbench.action.quickchat.toggle"
  }
]
